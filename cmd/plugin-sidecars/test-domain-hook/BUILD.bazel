load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("@rules_oci//oci:defs.bzl", "oci_image")
load("@rules_pkg//:pkg.bzl", "pkg_tar")

go_library(
    name = "go_default_library",
    srcs = ["main.go"],
    importpath = "kubevirt.io/kubevirt/cmd/plugin-sidecars/test-domain-hook",
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/hooks/plugins/v1alpha1:go_default_library",
        "//vendor/google.golang.org/grpc:go_default_library",
        "//vendor/google.golang.org/grpc/codes:go_default_library",
        "//vendor/google.golang.org/grpc/status:go_default_library",
        "//vendor/libvirt.org/go/libvirtxml:go_default_library",
    ],
)

go_binary(
    name = "test-domain-hook-sidecar",
    embed = [":go_default_library"],
    visibility = ["//visibility:public"],
)

pkg_tar(
    name = "test-domain-hook-sidecar-tar",
    srcs = [":test-domain-hook-sidecar"],
    package_dir = "/usr/bin",
)

oci_image(
    name = "test-domain-hook-sidecar-image",
    base = "//:passwd-image",
    entrypoint = ["/usr/bin/test-domain-hook-sidecar"],
    tars = [":test-domain-hook-sidecar-tar"],
    visibility = ["//visibility:public"],
)
