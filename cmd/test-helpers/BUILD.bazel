load("@rules_img//img:image.bzl", "image_manifest")
load("@rules_img//img:layer.bzl", "layer_from_tar")
load("@rules_pkg//:pkg.bzl", "pkg_tar")

pkg_tar(
    name = "test-pod-mutator-tar",
    testonly = True,
    srcs = ["//cmd/test-helpers/pod-mutator:test-pod-mutator"],
    package_dir = "/usr/bin",
)

layer_from_tar(
    name = "test-pod-mutator-layer",
    testonly = True,
    src = ":test-pod-mutator-tar",
)

image_manifest(
    name = "test-helpers-image",
    testonly = True,
    base = "//:passwd-image",
    layers = [
        ":test-pod-mutator-layer",
    ],
    visibility = ["//visibility:public"],
)
