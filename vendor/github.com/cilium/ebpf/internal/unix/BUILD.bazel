    visibility = ["//vendor/github.com/cilium/ebpf:__subpackages__"],
    deps = [
        "//vendor/github.com/cilium/ebpf/internal:go_default_library",
    ] + select({
        "@io_bazel_rules_go//go/platform:android": [
            "//vendor/golang.org/x/sys/unix:go_default_library",
