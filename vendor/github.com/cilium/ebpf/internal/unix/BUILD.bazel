        "doc.go",
        "errno_linux.go",
        "errno_other.go",
        "errno_string_windows.go",
        "errno_windows.go",
        "error.go",
        "strings_other.go",
        "strings_windows.go",
        "types_linux.go",
        "types_other.go",
    ],
    importmap = "kubevirt.io/kubevirt/vendor/github.com/cilium/ebpf/internal/unix",
